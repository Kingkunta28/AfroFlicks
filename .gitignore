# .gitignore for AfroFlicks

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Node modules (if using any build tools)
node_modules/
npm-debug.log
yarn-error.log

# Environment variables
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
*.min.js
*.min.css

# OS files
Thumbs.db
.DS_Store
.AppleDouble

# Testing
coverage/
.nyc_output/

# Logs
logs/
*.log

# Temporary files
temp/
tmp/
*.tmp

# API Keys and secrets
config.js (use config.example.js instead)

# Cache
.cache/
*.cache

# Backup files
*.bak
*.backup
