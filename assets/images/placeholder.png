<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Placeholder</title>
  <style>
    body { margin: 0; background: #111111; }
    svg { width: 100%; height: 100%; display: block; }
  </style>
</head>
<body>
  <svg viewBox="0 0 300 450" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#FFD700;stop-opacity:0.3" />
        <stop offset="100%" style="stop-color:#FFC700;stop-opacity:0.3" />
      </linearGradient>
    </defs>
    <rect width="300" height="450" fill="#1a1a1a" stroke="#333333" stroke-width="2"/>
    <rect width="300" height="450" fill="url(#grad)"/>
    <circle cx="150" cy="180" r="60" fill="none" stroke="#FFD700" stroke-width="2" opacity="0.5"/>
    <path d="M 150 140 L 180 180 L 150 220 L 120 180 Z" fill="#FFD700" opacity="0.5"/>
    <text x="150" y="300" font-family="Arial, sans-serif" font-size="16" fill="#B3B3B3" text-anchor="middle" opacity="0.7">
      Movie Poster
    </text>
    <text x="150" y="330" font-family="Arial, sans-serif" font-size="12" fill="#666666" text-anchor="middle" opacity="0.5">
      Image not available
    </text>
  </svg>
</body>
</html>
